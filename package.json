{
  "name": "translation-panel",
  "version": "1.0.0",
  "description": "Global translation panel for any application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run dev:renderer & wait-on http://localhost:5173 && npm run dev:main",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "google-translate-api-x": "^10.0.0"
  }
}
